# Runtime secrets (route handlers + client)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Offline ingestion only — never imported from app/
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Offline seed script only (scripts/seed-plant.ts) — never imported from app/.
# Grab from Supabase dashboard: Project Settings → Database → Connection string
# → "Transaction" pooler on port 6543.
SUPABASE_DB_URL=postgres://postgres.xxxxxxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Daily salt used for hashing IPs/user IDs in logs (lib/logger.ts).
# Optional: if unset, logger generates an ephemeral in-memory salt at startup.
LOG_HASH_SALT=

# Assistant Cloud (starter template only — not used in production routes)
# NEXT_PUBLIC_ASSISTANT_BASE_URL=
# ASSISTANT_API_KEY=
