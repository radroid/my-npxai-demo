# Runtime secrets (route handlers + client)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Offline ingestion only — never imported from app/
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- LOCAL SUPABASE (bun run db:local) --------------------------------------
# Full runbook: supabase/LOCAL.md
#
# To point the app at the local stack, replace ONLY these three lines in your
# .env.local with the block below. Leave OPENAI_API_KEY / UPSTASH_* alone —
# those still hit the real services.
#
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
#   SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
#
# These two JWTs are NOT secrets. They are the stock Supabase local demo keys
# (`iss: supabase-demo`), identical on every `supabase start` on every machine,
# published in Supabase's own docs, and signed with the well-known local JWT
# secret. They only ever unlock a Postgres running on your own laptop. Keeping
# them here (rather than in .env.local only) is what makes this file a usable
# copy-paste source. Never do this with a hosted project's keys.
#
# Re-print them any time with:  bunx supabase status -o env
# Keep your hosted values commented out alongside so you can swap back fast.

# Daily salt used for hashing IPs/user IDs in logs (lib/logger.ts).
# Optional: if unset, logger generates an ephemeral in-memory salt at startup.
LOG_HASH_SALT=

# Knowledge Hub artifact-mode model (lib/openai.ts getArtifactModel).
# Optional: defaults to gpt-4o-mini when unset.
OPENAI_ARTIFACT_MODEL=

# --- Eval harnesses (offline, manual `bun run` only — never in CI) -----------
# Rate-limit + circuit-breaker bypass (lib/guard.ts). Required by the eval
# runners that POST to the dev server; without it the anon tier caps them at
# 3 requests/min and 5/day and the first 429 aborts the run.
EVAL_BYPASS_KEY=
# Dev-server origin the eval runners target. Optional: defaults to
# http://localhost:3001.
EVAL_BASE_URL=
# LLM-as-judge model for the RAG eval framework (scripts/rag-eval/).
# Optional: defaults to gpt-4o — one tier above the gpt-4o-mini answerer.
EVAL_JUDGE_MODEL=
# Hard per-run budget guard for the RAG eval framework, in USD. The run aborts
# (and finalizes its logs) the moment actual+estimated spend reaches it.
# Optional: defaults to 2.
EVAL_COST_CAP_USD=
